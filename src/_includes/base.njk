<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ title or "Dashboard" }} · ContentIQ</title>
<script>
  // Runs immediately, before charts or anything else, so stored display
  // preferences are already applied to <html> by the time any chart reads
  // its colors. Without this, charts would always construct using the
  // untouched default color, since the full settings script runs later,
  // after the page's own content and charts.
  (function(){
    var root = document.documentElement;
    function get(key){ try { return localStorage.getItem(key); } catch(e){ return null; } }

    var themeMode = get('contentiq-theme-mode') || 'auto';
    if (themeMode === 'light' || themeMode === 'dark') {
      root.setAttribute('data-theme', themeMode);
    } else {
      var cached = null;
      try { cached = JSON.parse(localStorage.getItem('contentiq-suntimes') || 'null'); } catch(e){}
      if (cached && cached.forDate === new Date().toDateString()) {
        var now = Date.now(), sunrise = new Date(cached.sunrise).getTime(), sunset = new Date(cached.sunset).getTime();
        root.setAttribute('data-theme', (now < sunrise || now > sunset) ? 'dark' : 'light');
      } else {
        var h = new Date().getHours();
        root.setAttribute('data-theme', (h >= 19 || h < 7) ? 'dark' : 'light');
      }
    }

    root.setAttribute('data-color', get('contentiq-color') || 'sage');
    root.setAttribute('data-colorblind', get('contentiq-colorblind') || 'off');
    root.setAttribute('data-font', get('contentiq-font') || 'default');
    root.setAttribute('data-width', get('contentiq-width') || 'normal');
  })();
</script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
<script src="/mydashboard/vendor/chart.umd.js"></script>
<style>
  :root{
    --bg:#F1EFEA; --surface:#FAF9F6; --ink:#211F1C; --ink-soft:#6E6A62;
    --line:#DCD8CF; --accent:#3E5C55; --accent-soft:#DEE6E2; --logo-mark:#F1EFEA;
    --mono:'JetBrains Mono',monospace; --sans:'Inter',sans-serif; --display:'Space Grotesk',sans-serif;
    --content-font-size:16px; --page-width:1080px;
  }
  html[data-theme="dark"]{
    --bg:#18191B; --surface:#212225; --ink:#EDEBE5; --ink-soft:#8F8B82;
    --line:#2E2F2F; --accent:#75A594; --accent-soft:#22322C; --logo-mark:#18191B;
  }

  /* ---------- Color palettes, light mode ---------- */
  html[data-color="ocean"]{ --accent:#2A5C7A; --accent-soft:#DCE8EF; }
  html[data-color="amber"]{ --accent:#A5680A; --accent-soft:#F0E4D0; }
  html[data-color="berry"]{ --accent:#7A3B5C; --accent-soft:#EDDCE6; }
  /* ---------- Color palettes, dark mode ---------- */
  html[data-theme="dark"][data-color="ocean"]{ --accent:#6FA8C9; --accent-soft:#1E3644; }
  html[data-theme="dark"][data-color="amber"]{ --accent:#E0A94D; --accent-soft:#3A2E18; }
  html[data-theme="dark"][data-color="berry"]{ --accent:#C97FA8; --accent-soft:#3A2430; }
  /* ---------- Colorblind-safe override, wins regardless of data-color ---------- */
  html[data-colorblind="on"]{ --accent:#1D6FA5; --accent-soft:#DCE9F2; }
  html[data-theme="dark"][data-colorblind="on"]{ --accent:#5FA8DE; --accent-soft:#1B2E3D; }

  /* ---------- Font size ---------- */
  html[data-font="small"]{ --content-font-size:14px; }
  html[data-font="default"]{ --content-font-size:16px; }
  html[data-font="large"]{ --content-font-size:18px; }
  html[data-font="xlarge"]{ --content-font-size:21px; }

  /* ---------- Page width / margins ---------- */
  html[data-width="narrow"]{ --page-width:820px; }
  html[data-width="normal"]{ --page-width:1080px; }
  html[data-width="wide"]{ --page-width:1320px; }

  *{ box-sizing:border-box; }
  body{ margin:0; background:var(--bg); color:var(--ink); font-family:var(--sans); -webkit-font-smoothing:antialiased; transition:background .25s ease,color .25s ease; }
  a{ color:inherit; }
  :focus-visible{ outline:2px solid var(--accent); outline-offset:3px; }
  .wrap{ max-width:var(--page-width, 1080px); margin:0 auto; padding:0 28px; transition:max-width .2s ease; }
  .topbar{ padding:24px 0; border-bottom:1px solid var(--line); margin-bottom:40px; }
  .topbar .wrap{ display:flex; align-items:center; justify-content:space-between; }
  .brandmark{ display:flex; align-items:center; gap:10px; text-decoration:none; }
  .brandmark .word{ font-family:var(--mono); font-size:13px; letter-spacing:.08em; color:var(--ink-soft); text-transform:uppercase; }
  .brandmark .word b{ color:var(--ink); font-weight:600; }
  .last-updated{ font-family:var(--mono); font-size:11px; color:var(--ink-soft); opacity:.75; margin:0 0 20px; }

  .top-actions{ display:flex; align-items:center; gap:10px; position:relative; }
  .settings-btn{ display:flex; align-items:center; justify-content:center; width:34px; height:34px; border-radius:50%; border:1px solid var(--line); background:var(--surface); cursor:pointer; color:var(--ink-soft); }
  .settings-btn svg{ width:16px; height:16px; }
  .settings-btn:hover{ color:var(--ink); border-color:var(--accent); }

  .settings-panel{
    display:none; position:absolute; top:44px; right:0; width:300px; z-index:50;
    background:var(--surface); border:1px solid var(--line); border-radius:10px;
    padding:18px; box-shadow:0 8px 24px rgba(0,0,0,0.12);
  }
  .settings-panel.open{ display:block; }
  .settings-group{ margin-bottom:16px; }
  .settings-group:last-child{ margin-bottom:0; }
  .settings-group-label{ font-family:var(--mono); font-size:10px; text-transform:uppercase; letter-spacing:.06em; color:var(--ink-soft); margin:0 0 8px; }
  .settings-row{ display:flex; gap:6px; flex-wrap:wrap; }
  .settings-btn-opt{
    font-family:var(--mono); font-size:11px; padding:6px 10px; border-radius:14px;
    border:1px solid var(--line); background:var(--bg); color:var(--ink-soft); cursor:pointer;
  }
  .settings-btn-opt:hover{ border-color:var(--accent); color:var(--ink); }
  .settings-btn-opt.active{ background:var(--accent); border-color:var(--accent); color:var(--bg); }
  .color-swatch{ width:26px; height:26px; border-radius:50%; border:2px solid var(--line); cursor:pointer; padding:0; }
  .color-swatch.active{ border-color:var(--ink); }
  .swatch-sage{ background:#3E5C55; } .swatch-ocean{ background:#2A5C7A; }
  .swatch-amber{ background:#A5680A; } .swatch-berry{ background:#7A3B5C; }
  .colorblind-toggle{ display:flex; align-items:center; gap:8px; font-size:12px; color:var(--ink-soft); cursor:pointer; }

  .theme-toggle-icon svg{ width:16px; height:16px; }

  main{ padding-bottom:80px; font-size:var(--content-font-size, 16px); }
  .eyebrow{ font-family:var(--mono); font-size:12px; letter-spacing:.12em; text-transform:uppercase; color:var(--accent); margin:0 0 10px; }
  h1.page-title{ font-family:var(--display); font-weight:600; font-size:clamp(26px,4vw,38px); letter-spacing:-.02em; margin:0 0 8px; }
  .subtitle{ color:var(--ink-soft); font-size:15px; margin:0 0 36px; }
  .metrics-toggle{ display:flex; gap:8px; margin-bottom:24px; }
  .range-toggle{ display:flex; gap:8px; margin-bottom:16px; flex-wrap:wrap; }
  .range-btn{
    font-family:var(--mono); font-size:11px; text-transform:uppercase; letter-spacing:.06em;
    padding:6px 14px; border-radius:20px; border:1px solid var(--line);
    background:var(--surface); color:var(--ink-soft); cursor:pointer; transition:all .15s ease;
  }
  .range-btn:hover{ border-color:var(--accent); color:var(--ink); }
  .range-btn.active{ background:var(--accent); border-color:var(--accent); color:var(--bg); }
  .custom-range-inputs{ display:flex; align-items:center; gap:8px; margin-bottom:16px; font-size:13px; color:var(--ink-soft); }
  .custom-range-inputs input[type="date"]{
    font-family:var(--sans); font-size:12px; padding:5px 8px; border-radius:6px;
    border:1px solid var(--line); background:var(--surface); color:var(--ink);
  }
  .custom-range-inputs button{
    font-family:var(--mono); font-size:11px; text-transform:uppercase; padding:5px 12px;
    border-radius:16px; border:1px solid var(--accent); background:var(--accent); color:var(--bg); cursor:pointer;
  }
  .metrics-btn{
    font-family:var(--mono); font-size:12px; text-transform:uppercase; letter-spacing:.06em;
    padding:8px 16px; border-radius:20px; border:1px solid var(--line);
    background:var(--surface); color:var(--ink-soft); cursor:pointer; transition:all .15s ease;
  }
  .metrics-btn:hover{ border-color:var(--accent); color:var(--ink); }
  .metrics-btn.active{ background:var(--accent); border-color:var(--accent); color:var(--bg); }

  .kpi-grid{ display:grid; grid-template-columns:repeat(4,1fr); gap:14px; margin-bottom:40px; }
  .kpi-card{ background:var(--surface); border:1px solid var(--line); border-radius:10px; padding:18px; }
  .kpi-label{ font-family:var(--mono); font-size:11px; text-transform:uppercase; letter-spacing:.08em; color:var(--ink-soft); margin:0 0 8px; }
  .kpi-value{ font-family:var(--display); font-weight:600; font-size:26px; }
  .card{ background:var(--surface); border:1px solid var(--line); border-radius:10px; padding:24px; margin-bottom:32px; }
  .card h2{ font-family:var(--display); font-weight:600; font-size:18px; margin:0 0 18px; }
  table{ width:100%; border-collapse:collapse; font-size:var(--content-font-size, 14px); }
  th{ font-family:var(--mono); font-size:11px; text-transform:uppercase; letter-spacing:.06em; color:var(--ink-soft); text-align:left; padding:10px 12px; border-bottom:1px solid var(--line); }
  td{ padding:12px; border-bottom:1px solid var(--line); }
  tr:last-child td{ border-bottom:none; }
  tr:hover td{ background:var(--accent-soft); }
  .type-pill{ font-family:var(--mono); font-size:10px; text-transform:uppercase; letter-spacing:.04em; background:var(--accent-soft); color:var(--accent); padding:3px 9px; border-radius:20px; white-space:nowrap; }
  .rate-good{ color:var(--accent); font-weight:600; }
  a.post-link{ text-decoration:none; color:var(--accent); font-weight:500; }
  a.post-link:hover{ text-decoration:underline; }
  .back-link{ font-family:var(--mono); font-size:13px; color:var(--ink-soft); text-decoration:none; }
  .back-link:hover{ color:var(--accent); }
  .meta-row{ display:flex; gap:24px; flex-wrap:wrap; margin:20px 0 30px; font-size:13px; }
  .meta-item .label{ font-family:var(--mono); font-size:10px; text-transform:uppercase; color:var(--ink-soft); letter-spacing:.06em; }
  .meta-item .value{ font-weight:600; font-size:15px; }
  @media (max-width:700px){ .kpi-grid{ grid-template-columns:repeat(2,1fr); } table{ font-size:12px; } th,td{ padding:8px 6px; } .settings-panel{ width:260px; } }
</style>
</head>
<body>
<div class="topbar">
  <div class="wrap">
    <a class="brandmark" href="/">
      <svg width="22" height="22" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect width="40" height="40" rx="10" fill="var(--accent)"/>
        <path d="M9 25L15.5 18L20.5 22.5L31 11" stroke="var(--logo-mark)" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/>
        <circle cx="31" cy="11" r="2.6" fill="var(--logo-mark)"/>
      </svg>
      <span class="word"><b>ContentIQ</b> · Dashboard</span>
    </a>

    <div class="top-actions">
      <button class="settings-btn" id="settings-btn" type="button" aria-label="Display settings">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 11-2.83 2.83l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 11-2.83-2.83l.06-.06a1.65 1.65 0 00.33-1.82 1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 112.83-2.83l.06.06a1.65 1.65 0 001.82.33H9a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 112.83 2.83l-.06.06a1.65 1.65 0 00-.33 1.82V9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/></svg>
      </button>

      <div class="settings-panel" id="settings-panel">

        <div class="settings-group">
          <p class="settings-group-label">Theme</p>
          <div class="settings-row">
            <button class="settings-btn-opt" data-theme-choice="light" type="button">Light</button>
            <button class="settings-btn-opt" data-theme-choice="dark" type="button">Dark</button>
            <button class="settings-btn-opt" data-theme-choice="auto" type="button">Auto</button>
          </div>
        </div>

        <div class="settings-group">
          <p class="settings-group-label">Color</p>
          <div class="settings-row">
            <button class="color-swatch swatch-sage" data-color="sage" type="button" aria-label="Sage"></button>
            <button class="color-swatch swatch-ocean" data-color="ocean" type="button" aria-label="Ocean"></button>
            <button class="color-swatch swatch-amber" data-color="amber" type="button" aria-label="Amber"></button>
            <button class="color-swatch swatch-berry" data-color="berry" type="button" aria-label="Berry"></button>
          </div>
          <label class="colorblind-toggle" style="margin-top:10px;">
            <input type="checkbox" id="colorblind-check">
            Colorblind friendly mode
          </label>
        </div>

        <div class="settings-group">
          <p class="settings-group-label">Text size</p>
          <div class="settings-row">
            <button class="settings-btn-opt" data-font="small" type="button">A</button>
            <button class="settings-btn-opt" data-font="default" type="button">A</button>
            <button class="settings-btn-opt" data-font="large" type="button">A</button>
            <button class="settings-btn-opt" data-font="xlarge" type="button">A</button>
          </div>
        </div>

        <div class="settings-group">
          <p class="settings-group-label">Page width</p>
          <div class="settings-row">
            <button class="settings-btn-opt" data-width="narrow" type="button">Narrow</button>
            <button class="settings-btn-opt" data-width="normal" type="button">Normal</button>
            <button class="settings-btn-opt" data-width="wide" type="button">Wide</button>
          </div>
        </div>

      </div>
    </div>
  </div>
</div>
<main class="wrap">
  <p class="last-updated">Data last refreshed {{ buildTime | readableDateTime }}</p>
  {{ content | safe }}
</main>
<script>
  (function(){
    var root = document.documentElement;
    var settingsBtn = document.getElementById('settings-btn');
    var settingsPanel = document.getElementById('settings-panel');
    var colorblindCheck = document.getElementById('colorblind-check');

    function getStored(key){ try { return localStorage.getItem(key); } catch(e){ return null; } }
    function setStored(key, val){ try { localStorage.setItem(key, val); } catch(e){} }
    function clearStored(key){ try { localStorage.removeItem(key); } catch(e){} }

    // ---------- Panel open/close ----------
    settingsBtn.addEventListener('click', function(e){
      e.stopPropagation();
      settingsPanel.classList.toggle('open');
    });
    document.addEventListener('click', function(e){
      if (!settingsPanel.contains(e.target) && e.target !== settingsBtn) {
        settingsPanel.classList.remove('open');
      }
    });

    // ---------- Theme: light / dark / auto ----------
    function timeBased(){ var h=new Date().getHours(); return (h>=19||h<7)?'dark':'light'; }

    function isDarkFromSunTimes(sunriseISO, sunsetISO){
      var now = Date.now();
      var sunrise = new Date(sunriseISO).getTime();
      var sunset = new Date(sunsetISO).getTime();
      if (isNaN(sunrise) || isNaN(sunset)) return null;
      return (now < sunrise || now > sunset) ? 'dark' : 'light';
    }
    function getCachedSunTimes(){
      try {
        var cached = JSON.parse(localStorage.getItem('contentiq-suntimes') || 'null');
        if (!cached) return null;
        if (cached.forDate !== new Date().toDateString()) return null;
        return cached;
      } catch(e){ return null; }
    }
    function cacheSunTimes(sunrise, sunset){
      try {
        localStorage.setItem('contentiq-suntimes', JSON.stringify({ forDate: new Date().toDateString(), sunrise: sunrise, sunset: sunset }));
      } catch(e){}
    }
    function applyAutoTheme(){
      var cached = getCachedSunTimes();
      if (cached) {
        var result = isDarkFromSunTimes(cached.sunrise, cached.sunset);
        if (result) root.setAttribute('data-theme', result);
        return;
      }
      root.setAttribute('data-theme', timeBased());
      if (!navigator.geolocation) return;
      navigator.geolocation.getCurrentPosition(function(pos){
        var url = 'https://api.sunrise-sunset.org/json?lat=' + pos.coords.latitude + '&lng=' + pos.coords.longitude + '&formatted=0';
        fetch(url).then(function(r){ return r.json(); }).then(function(data){
          if (data.status !== 'OK') return;
          cacheSunTimes(data.results.sunrise, data.results.sunset);
          if (getStored('contentiq-theme-mode') === 'auto' || !getStored('contentiq-theme-mode')) {
            var result = isDarkFromSunTimes(data.results.sunrise, data.results.sunset);
            if (result) root.setAttribute('data-theme', result);
          }
        }).catch(function(){});
      }, function(){}, { timeout: 4000 });
    }

    function setThemeMode(mode){
      setStored('contentiq-theme-mode', mode);
      if (mode === 'light' || mode === 'dark') {
        root.setAttribute('data-theme', mode);
      } else {
        applyAutoTheme();
      }
      document.querySelectorAll('[data-theme-choice]').forEach(function(b){
        b.classList.toggle('active', b.dataset.themeChoice === mode);
      });
    }

    document.querySelectorAll('[data-theme-choice]').forEach(function(btn){
      btn.addEventListener('click', function(){ setThemeMode(btn.dataset.themeChoice); });
    });

    setInterval(function(){
      if (getStored('contentiq-theme-mode') === 'auto' || !getStored('contentiq-theme-mode')) applyAutoTheme();
    }, 5 * 60 * 1000);

    // ---------- Color palette + colorblind ----------
    function setColor(color){
      root.setAttribute('data-color', color);
      setStored('contentiq-color', color);
      document.querySelectorAll('[data-color]').forEach(function(b){
        if (b.tagName === 'BUTTON') b.classList.toggle('active', b.dataset.color === color);
      });
    }
    document.querySelectorAll('.color-swatch').forEach(function(btn){
      btn.addEventListener('click', function(){ setColor(btn.dataset.color); });
    });

    function setColorblind(on){
      root.setAttribute('data-colorblind', on ? 'on' : 'off');
      setStored('contentiq-colorblind', on ? 'on' : 'off');
      colorblindCheck.checked = on;
    }
    colorblindCheck.addEventListener('change', function(){ setColorblind(colorblindCheck.checked); });

    // ---------- Font size ----------
    function setFont(size){
      root.setAttribute('data-font', size);
      setStored('contentiq-font', size);
      document.querySelectorAll('[data-font]').forEach(function(b){ b.classList.toggle('active', b.dataset.font === size); });
    }
    document.querySelectorAll('[data-font]').forEach(function(btn){
      btn.addEventListener('click', function(){ setFont(btn.dataset.font); });
    });

    // ---------- Page width ----------
    function setWidth(w){
      root.setAttribute('data-width', w);
      setStored('contentiq-width', w);
      document.querySelectorAll('[data-width]').forEach(function(b){ b.classList.toggle('active', b.dataset.width === w); });
    }
    document.querySelectorAll('.settings-row [data-width]').forEach(function(btn){
      btn.addEventListener('click', function(){ setWidth(btn.dataset.width); });
    });

    // ---------- Initialize everything from storage ----------
    setThemeMode(getStored('contentiq-theme-mode') || 'auto');
    setColor(getStored('contentiq-color') || 'sage');
    setColorblind(getStored('contentiq-colorblind') === 'on');
    setFont(getStored('contentiq-font') || 'default');
    setWidth(getStored('contentiq-width') || 'normal');
  })();
</script>
</body>
</html>
