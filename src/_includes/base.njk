<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ title or "Dashboard" }} · ContentIQ</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.4/chart.umd.min.js"></script>
<style>
  :root{
    --bg:#F1EFEA; --surface:#FAF9F6; --ink:#211F1C; --ink-soft:#6E6A62;
    --line:#DCD8CF; --accent:#3E5C55; --accent-soft:#DEE6E2; --logo-mark:#F1EFEA;
    --mono:'JetBrains Mono',monospace; --sans:'Inter',sans-serif; --display:'Space Grotesk',sans-serif;
  }
  html[data-theme="dark"]{
    --bg:#18191B; --surface:#212225; --ink:#EDEBE5; --ink-soft:#8F8B82;
    --line:#2E2F2F; --accent:#75A594; --accent-soft:#22322C; --logo-mark:#18191B;
  }
  *{ box-sizing:border-box; }
  body{ margin:0; background:var(--bg); color:var(--ink); font-family:var(--sans); -webkit-font-smoothing:antialiased; transition:background .25s ease,color .25s ease; }
  a{ color:inherit; }
  :focus-visible{ outline:2px solid var(--accent); outline-offset:3px; }
  .wrap{ max-width:1080px; margin:0 auto; padding:0 28px; }
  .topbar{ padding:24px 0; border-bottom:1px solid var(--line); margin-bottom:40px; }
  .topbar .wrap{ display:flex; align-items:center; justify-content:space-between; }
  .brandmark{ display:flex; align-items:center; gap:10px; text-decoration:none; }
  .brandmark .word{ font-family:var(--mono); font-size:13px; letter-spacing:.08em; color:var(--ink-soft); text-transform:uppercase; }
  .brandmark .word b{ color:var(--ink); font-weight:600; }
  .theme-toggle{ display:flex; align-items:center; justify-content:center; width:34px; height:34px; border-radius:50%; border:1px solid var(--line); background:var(--surface); cursor:pointer; color:var(--ink-soft); }
  .theme-toggle svg{ width:16px; height:16px; }
  .theme-toggle .icon-moon{ display:none; }
  html[data-theme="dark"] .theme-toggle .icon-sun{ display:none; }
  html[data-theme="dark"] .theme-toggle .icon-moon{ display:block; }
  main{ padding-bottom:80px; }
  .eyebrow{ font-family:var(--mono); font-size:12px; letter-spacing:.12em; text-transform:uppercase; color:var(--accent); margin:0 0 10px; }
  h1.page-title{ font-family:var(--display); font-weight:600; font-size:clamp(26px,4vw,38px); letter-spacing:-.02em; margin:0 0 8px; }
  .subtitle{ color:var(--ink-soft); font-size:15px; margin:0 0 36px; }
  .metrics-toggle{ display:flex; gap:8px; margin-bottom:24px; }
  .metrics-btn{
    font-family:var(--mono); font-size:12px; text-transform:uppercase; letter-spacing:.06em;
    padding:8px 16px; border-radius:20px; border:1px solid var(--line);
    background:var(--surface); color:var(--ink-soft); cursor:pointer; transition:all .15s ease;
  }
  .metrics-btn:hover{ border-color:var(--accent); color:var(--ink); }
  .metrics-btn.active{ background:var(--accent); border-color:var(--accent); color:var(--bg); }

  .kpi-grid{ display:grid; grid-template-columns:repeat(4,1fr); gap:14px; margin-bottom:40px; }
  .kpi-card{ background:var(--surface); border:1px solid var(--line); border-radius:10px; padding:18px; }
  .kpi-label{ font-family:var(--mono); font-size:11px; text-transform:uppercase; letter-spacing:.08em; color:var(--ink-soft); margin:0 0 8px; }
  .kpi-value{ font-family:var(--display); font-weight:600; font-size:26px; }
  .card{ background:var(--surface); border:1px solid var(--line); border-radius:10px; padding:24px; margin-bottom:32px; }
  .card h2{ font-family:var(--display); font-weight:600; font-size:18px; margin:0 0 18px; }
  table{ width:100%; border-collapse:collapse; font-size:14px; }
  th{ font-family:var(--mono); font-size:11px; text-transform:uppercase; letter-spacing:.06em; color:var(--ink-soft); text-align:left; padding:10px 12px; border-bottom:1px solid var(--line); }
  td{ padding:12px; border-bottom:1px solid var(--line); }
  tr:last-child td{ border-bottom:none; }
  tr:hover td{ background:var(--accent-soft); }
  .type-pill{ font-family:var(--mono); font-size:10px; text-transform:uppercase; letter-spacing:.04em; background:var(--accent-soft); color:var(--accent); padding:3px 9px; border-radius:20px; white-space:nowrap; }
  .rate-good{ color:var(--accent); font-weight:600; }
  a.post-link{ text-decoration:none; color:var(--accent); font-weight:500; }
  a.post-link:hover{ text-decoration:underline; }
  .back-link{ font-family:var(--mono); font-size:13px; color:var(--ink-soft); text-decoration:none; }
  .back-link:hover{ color:var(--accent); }
  .meta-row{ display:flex; gap:24px; flex-wrap:wrap; margin:20px 0 30px; font-size:13px; }
  .meta-item .label{ font-family:var(--mono); font-size:10px; text-transform:uppercase; color:var(--ink-soft); letter-spacing:.06em; }
  .meta-item .value{ font-weight:600; font-size:15px; }
  @media (max-width:700px){ .kpi-grid{ grid-template-columns:repeat(2,1fr); } table{ font-size:12px; } th,td{ padding:8px 6px; } }
</style>
</head>
<body>
<div class="topbar">
  <div class="wrap">
    <a class="brandmark" href="/">
      <svg width="22" height="22" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect width="40" height="40" rx="10" fill="var(--accent)"/>
        <path d="M9 25L15.5 18L20.5 22.5L31 11" stroke="var(--logo-mark)" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/>
        <circle cx="31" cy="11" r="2.6" fill="var(--logo-mark)"/>
      </svg>
      <span class="word"><b>ContentIQ</b> · Dashboard</span>
    </a>
    <button class="theme-toggle" id="theme-toggle" type="button" aria-label="Toggle dark mode">
      <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/></svg>
      <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.8A9 9 0 1111.2 3a7 7 0 009.8 9.8z"/></svg>
    </button>
  </div>
</div>
<main class="wrap">
  {{ content | safe }}
</main>
<script>
  (function(){
    var root=document.documentElement, btn=document.getElementById('theme-toggle');
    function getStored(){ try{return localStorage.getItem('contentiq-dash-theme');}catch(e){return null;} }
    function setStored(v){ try{localStorage.setItem('contentiq-dash-theme', v);}catch(e){} }
    function timeBased(){ var h=new Date().getHours(); return (h>=19||h<7)?'dark':'light'; }
    function apply(){ root.setAttribute('data-theme', getStored()||timeBased()); }
    apply();
    btn.addEventListener('click', function(){
      var next = root.getAttribute('data-theme')==='dark' ? 'light':'dark';
      root.setAttribute('data-theme', next); setStored(next);
    });
  })();
</script>
</body>
</html>
