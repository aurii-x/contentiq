---
layout: base.njk
pagination:
  data: posts
  size: 1
  alias: post
permalink: "/mydashboard/posts/{{ post.slug }}/"
eleventyComputed:
  title: "{{ post.topic }}"
---
<a class="back-link" href="/mydashboard/">&larr; Back to all posts</a>

<p class="eyebrow">{{ post.pillar }}</p>
<h1 class="page-title">{{ post.topic }}</h1>

<div class="meta-row">
  <div class="meta-item">
    <p class="label">Published</p>
    <p class="value">{{ post.date }}</p>
  </div>
  <div class="meta-item">
    <p class="label">Type</p>
    <p class="value">{{ post.contentType }}</p>
  </div>
  <div class="meta-item">
    <p class="label">Latest Impressions</p>
    <p class="value">{{ post.impressions }}</p>
  </div>
  <div class="meta-item">
    <p class="label">Latest Engagements</p>
    <p class="value">{{ post.engagements }}</p>
  </div>
  <div class="meta-item">
    <p class="label">Engagement Rate</p>
    <p class="value">{{ post.engagementRate | pct }}</p>
  </div>
</div>

<div class="card">
  <h2>Performance Over Time</h2>
  {% if post.history.length > 1 %}
  <div class="range-toggle">
    <button class="range-btn" data-range="7" type="button">7 days</button>
    <button class="range-btn" data-range="14" type="button">14 days</button>
    <button class="range-btn" data-range="30" type="button">30 days</button>
    <button class="range-btn active" data-range="all" type="button">All time</button>
    <button class="range-btn" data-range="custom" type="button">Custom</button>
  </div>
  <div class="custom-range-inputs" id="custom-range-inputs" style="display:none;">
    <input type="date" id="range-start">
    <span>to</span>
    <input type="date" id="range-end">
    <button type="button" id="apply-custom-range">Apply</button>
  </div>
  <canvas id="postChart" height="100"></canvas>
  {% else %}
  <p style="color:var(--ink-soft); font-size:14px;">Only one data pull recorded for this post so far. The growth chart needs at least 2 pulls to show a trend, check back after the next export.</p>
  {% endif %}
</div>

<div class="card">
  <h2>Raw Pull History</h2>
  <table>
    <thead>
      <tr><th>Pulled On</th><th>Impressions</th><th>Engagements</th></tr>
    </thead>
    <tbody>
      {% for h in post.history %}
      <tr>
        <td>{{ h.pulled_at }}</td>
        <td>{{ h.impressions }}</td>
        <td>{{ h.engagements }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
</div>

<p><a class="back-link" href="{{ post.url }}" target="_blank" rel="noopener">View original post on LinkedIn &rarr;</a></p>

{% if post.history.length > 1 %}
<script>
  var postHistory = {{ post.history | json | safe }};
  var styles = getComputedStyle(document.documentElement);
  var accent = styles.getPropertyValue('--accent').trim();
  var inkSoft = styles.getPropertyValue('--ink-soft').trim();
  var line = styles.getPropertyValue('--line').trim();

  var postChart = new Chart(document.getElementById('postChart'), {
    type: 'line',
    data: {
      labels: postHistory.map(function(h){ return h.pulled_at; }),
      datasets: [
        { label: 'Impressions', data: postHistory.map(function(h){ return h.impressions; }), borderColor: accent, backgroundColor: accent, tension: 0.3, yAxisID: 'y' },
        { label: 'Engagements', data: postHistory.map(function(h){ return h.engagements; }), borderColor: inkSoft, backgroundColor: inkSoft, tension: 0.3, yAxisID: 'y1' }
      ]
    },
    options: {
      responsive: true,
      plugins: { legend: { labels: { color: inkSoft } } },
      scales: {
        y: { beginAtZero: true, position: 'left', grid: { color: line }, ticks: { color: inkSoft } },
        y1: { beginAtZero: true, position: 'right', grid: { display: false }, ticks: { color: inkSoft } },
        x: { grid: { display: false }, ticks: { color: inkSoft } }
      }
    }
  });

  (function(){
    var rangeButtons = document.querySelectorAll('.range-btn');
    var customInputs = document.getElementById('custom-range-inputs');
    var startInput = document.getElementById('range-start');
    var endInput = document.getElementById('range-end');
    var applyCustomBtn = document.getElementById('apply-custom-range');

    function filterHistory(rangeValue, customStart, customEnd){
      if (rangeValue === 'all') return postHistory;
      if (rangeValue === 'custom') {
        if (!customStart || !customEnd) return postHistory;
        var s = new Date(customStart), e = new Date(customEnd);
        return postHistory.filter(function(h){ var d = new Date(h.pulled_at); return d >= s && d <= e; });
      }
      var days = parseInt(rangeValue, 10);
      var cutoff = new Date();
      cutoff.setDate(cutoff.getDate() - days);
      return postHistory.filter(function(h){ return new Date(h.pulled_at) >= cutoff; });
    }

    function applyRange(rangeValue, customStart, customEnd){
      var filtered = filterHistory(rangeValue, customStart, customEnd);
      postChart.data.labels = filtered.map(function(h){ return h.pulled_at; });
      postChart.data.datasets[0].data = filtered.map(function(h){ return h.impressions; });
      postChart.data.datasets[1].data = filtered.map(function(h){ return h.engagements; });
      postChart.update();
      rangeButtons.forEach(function(b){ b.classList.toggle('active', b.dataset.range === rangeValue); });
      customInputs.style.display = rangeValue === 'custom' ? 'flex' : 'none';
    }

    rangeButtons.forEach(function(btn){ btn.addEventListener('click', function(){ applyRange(btn.dataset.range); }); });
    applyCustomBtn.addEventListener('click', function(){ applyRange('custom', startInput.value, endInput.value); });
  })();
</script>
{% endif %}
