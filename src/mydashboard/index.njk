---
layout: base.njk
title: "Dashboard"
---
<p class="eyebrow">Content Intelligence</p>
<h1 class="page-title">Post Performance Dashboard</h1>
<p class="subtitle">Tracking {{ posts.length }} tagged posts across {{ dailyTotals.length }} days of data</p>

<div class="metrics-toggle">
  <button class="metrics-btn active" data-metrics="relative" type="button">Relative view</button>
  <button class="metrics-btn" data-metrics="absolute" type="button">Exact numbers</button>
</div>

<div class="kpi-grid">
  <div class="kpi-card">
    <p class="kpi-label">Reach vs. Average Post</p>
    <p class="kpi-value abs-hide">{{ (posts | sum("impressions")) or 0 }}</p>
    <p class="kpi-value rel-hide" id="kpi-reach-index" style="display:none;" data-avg="{{ stats.avgImpressions }}" data-posts="{{ posts.length }}">—</p>
  </div>
  <div class="kpi-card">
    <p class="kpi-label">Engagement vs. Average Post</p>
    <p class="kpi-value abs-hide">{{ (posts | sum("engagements")) or 0 }}</p>
    <p class="kpi-value rel-hide" id="kpi-engagement-index" style="display:none;" data-avg="{{ stats.avgEngagements }}" data-posts="{{ posts.length }}">—</p>
  </div>
  <div class="kpi-card">
    <p class="kpi-label">Avg Engagement Rate</p>
    <p class="kpi-value">{{ stats.avgRate | pct }}</p>
  </div>
  <div class="kpi-card">
    <p class="kpi-label">Best Performer</p>
    <p class="kpi-value" style="font-size:16px;">{{ stats.bestPost.topic | truncate(28) }}</p>
  </div>
</div>

<div class="card">
  <h2>Engagement Rate by Pillar</h2>
  <canvas id="pillarChart" height="90"></canvas>
</div>

<div class="card">
  <h2>Account Impressions Over Time</h2>
  <div class="range-toggle">
    <button class="range-btn" data-range="7" type="button">7 days</button>
    <button class="range-btn" data-range="14" type="button">14 days</button>
    <button class="range-btn" data-range="30" type="button">30 days</button>
    <button class="range-btn active" data-range="all" type="button">All time</button>
    <button class="range-btn" data-range="custom" type="button">Custom</button>
  </div>
  <div class="custom-range-inputs" id="custom-range-inputs" style="display:none;">
    <input type="date" id="range-start">
    <span>to</span>
    <input type="date" id="range-end">
    <button type="button" id="apply-custom-range">Apply</button>
  </div>
  <canvas id="timelineChart" height="90"></canvas>
</div>

<div class="card">
  <h2>All Posts</h2>
  <table>
    <thead>
      <tr>
        <th>Date</th><th>Topic</th><th>Type</th><th>Pillar</th>
        <th class="abs-hide">Impressions</th><th class="abs-hide">Engagements</th>
        <th class="rel-hide" style="display:none;">Reach Index</th>
        <th>Rate</th>
      </tr>
    </thead>
    <tbody>
      {% for post in posts %}
      <tr>
        <td>{{ post.date }}</td>
        <td><a class="post-link" href="/mydashboard/posts/{{ post.slug }}/">{{ post.topic | truncate(35) }}</a></td>
        <td><span class="type-pill">{{ post.contentType }}</span></td>
        <td>{{ post.pillar }}</td>
        <td class="abs-hide">{{ post.impressions }}</td>
        <td class="abs-hide">{{ post.engagements }}</td>
        <td class="rel-hide" style="display:none;" data-impressions="{{ post.impressions }}" data-avg="{{ stats.avgImpressions }}"></td>
        <td class="{% if post.engagementRate >= 0.015 %}rate-good{% endif %}">{{ post.engagementRate | pct }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
</div>

<script>
  var posts = {{ posts | json | safe }};
  var daily = {{ dailyTotals | json | safe }};

  var pillarMap = {};
  posts.forEach(function(p){
    if (!pillarMap[p.pillar]) pillarMap[p.pillar] = { total: 0, count: 0 };
    pillarMap[p.pillar].total += p.engagementRate;
    pillarMap[p.pillar].count += 1;
  });
  var pillarLabels = Object.keys(pillarMap);
  var pillarData = pillarLabels.map(function(k){ return (pillarMap[k].total / pillarMap[k].count * 100).toFixed(2); });

  var styles = getComputedStyle(document.documentElement);
  var accent = styles.getPropertyValue('--accent').trim();
  var inkSoft = styles.getPropertyValue('--ink-soft').trim();
  var line = styles.getPropertyValue('--line').trim();

  // Fixed multi-color palette for this chart specifically, deliberately
  // NOT tied to the theme's accent color, stays constant regardless of
  // which color palette or theme is selected, so each pillar bar stays
  // visually distinct.
  var pillarPalette = ['#3E5C55', '#2A5C7A', '#A5680A', '#7A3B5C', '#5F7A3E', '#8A5C3E', '#3E5C7A', '#7A5C3E'];
  var pillarColors = pillarLabels.map(function(_, i){ return pillarPalette[i % pillarPalette.length]; });

  new Chart(document.getElementById('pillarChart'), {
    type: 'bar',
    data: { labels: pillarLabels, datasets: [{ label: 'Avg Engagement Rate %', data: pillarData, backgroundColor: pillarColors, borderRadius: 6 }] },
    options: {
      responsive: true,
      plugins: { legend: { display: false } },
      scales: {
        y: { beginAtZero: true, grid: { color: line }, ticks: { color: inkSoft } },
        x: { grid: { display: false }, ticks: { color: inkSoft } }
      }
    }
  });

  var timelineChart = new Chart(document.getElementById('timelineChart'), {
    type: 'line',
    data: {
      labels: daily.map(function(d){ return d.date; }),
      datasets: [{ label: 'Impressions', data: daily.map(function(d){ return d.impressions; }), borderColor: accent, backgroundColor: accent, tension: 0.3, fill: false }]
    },
    options: {
      responsive: true,
      plugins: { legend: { display: false } },
      scales: {
        y: { beginAtZero: true, grid: { color: line }, ticks: { color: inkSoft } },
        x: { grid: { display: false }, ticks: { color: inkSoft } }
      }
    }
  });

  // ---------- Date range filter ----------
  (function(){
    var rangeButtons = document.querySelectorAll('.range-btn');
    var customInputs = document.getElementById('custom-range-inputs');
    var startInput = document.getElementById('range-start');
    var endInput = document.getElementById('range-end');
    var applyCustomBtn = document.getElementById('apply-custom-range');

    function getStored(){ try { return localStorage.getItem('contentiq-date-range'); } catch(e){ return null; } }
    function setStored(v){ try { localStorage.setItem('contentiq-date-range', v); } catch(e){} }

    function filterDaily(rangeValue, customStart, customEnd){
      if (rangeValue === 'all') return daily;

      if (rangeValue === 'custom') {
        if (!customStart || !customEnd) return daily;
        var s = new Date(customStart), e = new Date(customEnd);
        return daily.filter(function(d){
          var dd = new Date(d.date);
          return dd >= s && dd <= e;
        });
      }

      var days = parseInt(rangeValue, 10);
      var cutoff = new Date();
      cutoff.setDate(cutoff.getDate() - days);
      return daily.filter(function(d){ return new Date(d.date) >= cutoff; });
    }

    function applyRange(rangeValue, customStart, customEnd){
      var filtered = filterDaily(rangeValue, customStart, customEnd);
      timelineChart.data.labels = filtered.map(function(d){ return d.date; });
      timelineChart.data.datasets[0].data = filtered.map(function(d){ return d.impressions; });
      timelineChart.update();

      rangeButtons.forEach(function(b){ b.classList.toggle('active', b.dataset.range === rangeValue); });
      customInputs.style.display = rangeValue === 'custom' ? 'flex' : 'none';

      if (rangeValue !== 'custom') setStored(rangeValue);
    }

    rangeButtons.forEach(function(btn){
      btn.addEventListener('click', function(){ applyRange(btn.dataset.range); });
    });

    applyCustomBtn.addEventListener('click', function(){
      applyRange('custom', startInput.value, endInput.value);
    });

    applyRange(getStored() || 'all');
  })();

  // ---------- Relative / Absolute metrics toggle ----------
  (function(){
    var buttons = document.querySelectorAll('.metrics-btn');

    function getStored(){ try { return localStorage.getItem('contentiq-metrics-view'); } catch(e){ return null; } }
    function setStored(v){ try { localStorage.setItem('contentiq-metrics-view', v); } catch(e){} }

    // Fill in the reach index cells once, from their data attributes
    document.querySelectorAll('[data-impressions]').forEach(function(cell){
      var impressions = parseFloat(cell.dataset.impressions) || 0;
      var avg = parseFloat(cell.dataset.avg) || 0;
      if (avg > 0) {
        var multiplier = impressions / avg;
        cell.textContent = multiplier.toFixed(1) + 'x avg';
      } else {
        cell.textContent = '—';
      }
    });

    // Top KPI cards: relative view shows "per post" average instead of the
    // full account total, a more size-agnostic number than the raw sum.
    var reachIndexEl = document.getElementById('kpi-reach-index');
    var engagementIndexEl = document.getElementById('kpi-engagement-index');
    if (reachIndexEl) {
      var avgImp = parseFloat(reachIndexEl.dataset.avg) || 0;
      reachIndexEl.textContent = avgImp > 0 ? Math.round(avgImp) + ' / post' : '—';
    }
    if (engagementIndexEl) {
      var avgEng = parseFloat(engagementIndexEl.dataset.avg) || 0;
      engagementIndexEl.textContent = avgEng > 0 ? avgEng.toFixed(1) + ' / post' : '—';
    }

    function setView(view){
      var showAbs = view === 'absolute';
      document.querySelectorAll('.abs-hide').forEach(function(el){ el.style.display = showAbs ? '' : 'none'; });
      document.querySelectorAll('.rel-hide').forEach(function(el){ el.style.display = showAbs ? 'none' : ''; });
      buttons.forEach(function(b){ b.classList.toggle('active', b.dataset.metrics === view); });
      setStored(view);
    }

    setView(getStored() || 'relative');

    buttons.forEach(function(btn){
      btn.addEventListener('click', function(){ setView(btn.dataset.metrics); });
    });
  })();
</script>
